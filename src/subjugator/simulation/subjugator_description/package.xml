<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>subjugator_description</name>
  <version>0.0.0</version>
  <description>SDFormat description files for the subjugator project</description>
  <maintainer email="keith.khadar@gmail.com">Keith Khadar</maintainer>
  <license>Apache 2.0</license>
  <author>Keith Khadar</author>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <!-- sub9.urdf is expanded from sub9_sim.urdf.xacro at build time (see CMakeLists). -->
  <build_depend>mission_planner</build_depend>
  <build_depend>xacro</build_depend>

  <!-- sub9_sim.urdf.xacro loads mission_planner/config/grasp_targets.yaml at xacro
       expansion time (now build time) for the GripperControl <graspable> allowlist,
       so mission_planner must build first. -->
  <exec_depend>mission_planner</exec_depend>

  <test_depend>ament_lint_auto</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
