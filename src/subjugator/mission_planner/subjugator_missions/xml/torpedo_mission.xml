<!--
    TorpedoMission
    ==============
    Full run, assembled from independently-testable pieces:

      0) CheckYoloModel  - make sure the torpedo pose model is loaded
      1) ArchToFaceBoard - orbit so we face the board head-on   (torpedo_arch.xml)
      2) HomeAndFire     - large hole -> torpedo angle 1        (torpedo_home_fire.xml)
      3) HomeAndFire     - small hole -> torpedo angle 2        (torpedo_home_fire.xml)

    Choosing the task: this run targets SEARCH & RESCUE. To shoot the SURVEY &
    REPAIR board instead, swap the two hole_label values to
    "survey&amp;repair_large" / "survey&amp;repair_small".
    (& must be written &amp; inside XML attributes; the node sees "search&rescue_large".)

    Keypoints: the board's 4 corner keypoints only flow on /yolo/tracking. The
    planner subscribes to both /yolo/detections and /yolo/tracking at once; the arch
    (BoardArchStep) reads tracking for the keypoints while everything else reads the
    plain detections, so no topic remap is needed  just make sure yolo is launched
    with tracking on:
      ros2 run mission_planner mission_planner_node ros-args \
        -p mission:=TorpedoMission
      (launch yolo with use_tracking:=True)

    Test pieces in isolation with:
      mission:=ArchToFaceBoard   (just the arch)
      mission:=ServoTestMission  (just the torpedo servo)
-->

<root BTCPP_format="4" main_tree_to_execute="TorpedoMission">
  <BehaviorTree ID="TorpedoMission">
    <Sequence>

      <!-- 0) Correct YOLO model -->
      <Action ID="CheckYoloModel"
              model_filename="yolov26_torpedo_nano_June17.pt"
              yolo_node="/yolo/yolo_node"
              models_rel_dir="models"
              ctx="{ctx}"/>


      <!-- 1) Square up with the board (comment out to skip the arch). -->
      <SubTree ID="ArchToFaceBoard" _autoremap="true" ctx="{ctx}"/>

      <!-- 2) Large hole, first torpedo. -->
      <SubTree ID="HomeAndFire" ctx="{ctx}"
               hole_label="search&amp;rescue_large" torpedo_angle="1"/>

      <!-- 3) Small hole, second torpedo. -->
      <SubTree ID="HomeAndFire" ctx="{ctx}"
               hole_label="search&amp;rescue_small" torpedo_angle="2"/>

    </Sequence>
  </BehaviorTree>
</root>
