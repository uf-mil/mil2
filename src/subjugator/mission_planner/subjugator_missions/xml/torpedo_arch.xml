<!--
    ArchToFaceBoard
    ================
    Squares the sub up with the torpedo board by orbiting ("arching") sideways
    until the board's left and right vertical edges look the same length.

    Standalone testable: run with `mission:=ArchToFaceBoard` to tune the arch in
    isolation. The whole step is small and bounded:
      - step_deg     : arc commanded per orbit step (keep small)
      - radius_m     : assumed distance to the board (orbit radius)
      - deadband_frac: how square is "square enough" before we stop
      - max_steps    : hard cap on how far we ever arch
      - dir_sign     : flip to -1.0 if the arch goes the wrong way
-->
<root BTCPP_format="4" main_tree_to_execute="ArchToFaceBoard">
  <BehaviorTree ID="ArchToFaceBoard">
    <Sequence>

      <!-- 1) Get the board roughly centred first so its 4 corner keypoints are
              reliable before we start measuring left-vs-right edge length. -->
      <Timeout msec="12000">
        <Action ID="AlignYaw"
                label="torpedoTarget"
                min_conf="0.20"
                kp="2.5"
                yaw_tol_norm="0.20"
                max_yaw_deg="15.0"
                ori_tol_deg="6.5"
                ctx="{ctx}"/>
      </Timeout>

      <Timeout msec="10000">
          <Action ID="AlignDepth"
                  label="torpedoTarget"
                  min_conf="0.30"
                  kp="0.75"
                  depth_tol_norm="0.08"
                  max_step_m="0.15"
                  pos_tol="0.20"
                  center_offset_px="40"
                  ctx="{ctx}"/>
      </Timeout>

      <ForceSuccess>
        <Timeout msec="30000">
          <RetryUntilSuccessful num_attempts="-1">
            <Fallback>
              <Condition ID="TargetBigEnough"
                         label="torpedoTarget"
                         min_height_px="150.0"
                         min_width_px="150.0"
                         min_conf="0.20"
                         consecutive_frames="2"
                         ctx="{ctx}"/>
              <Sequence>
                <SubTree ID="RelativeMove" _autoremap="true"
                         x="0.25" y="0.0" z="0.0"
                         roll_deg="0.0" pitch_deg="0.0" yaw_deg="0.0"
                         pos_tol="0.25" ori_tol_deg="30.0" msec="6000" ctx="{ctx}"/>
                <AlwaysFailure/>
              </Sequence>
            </Fallback>
          </RetryUntilSuccessful>
        </Timeout>
      </ForceSuccess>

      <!-- 3) Orbit in small steps until the board is head-on. BoardArchStep reads
              the /yolo/tracking stream internally because the corner keypoints only
              ride that topic. -->
      <Timeout msec="60000">
        <Action ID="BoardArchStep"
                board_label="torpedoTarget"
                min_conf="0.20"
                min_kp_conf="0.15"
                radius_m="1.5"
                step_deg="15.0"
                deadband_frac="0.05"
                dir_sign="1.0"
                max_steps="8"
                pos_tol="0.25"
                ori_tol_deg="6.0"
                ctx="{ctx}"/>
      </Timeout>

      <ForceSuccess>
        <Timeout msec="30000">
          <RetryUntilSuccessful num_attempts="-1">
            <Fallback>
              <Condition ID="TargetBigEnough"
                         label="torpedoTarget"
                         min_height_px="160.0"
                         min_width_px="160.0"
                         min_conf="0.20"
                         consecutive_frames="2"
                         ctx="{ctx}"/>
              <Sequence>
                <SubTree ID="RelativeMove" _autoremap="true"
                         x="0.25" y="0.0" z="0.0"
                         roll_deg="0.0" pitch_deg="0.0" yaw_deg="0.0"
                         pos_tol="0.25" ori_tol_deg="30.0" msec="6000" ctx="{ctx}"/>
                <AlwaysFailure/>
              </Sequence>
            </Fallback>
          </RetryUntilSuccessful>
        </Timeout>
      </ForceSuccess>

    </Sequence>
  </BehaviorTree>
</root>
