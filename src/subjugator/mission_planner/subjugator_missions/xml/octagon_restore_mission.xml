<root BTCPP_format="4" main_tree_to_execute="OctagonRestoreMission">
    <!--
        Calibration-free Task-5 acquisition: acoustically home on the octagon
        pinger (frequency-gated so the Task-4 pinger is ignored), descend until
        the down-cam sees the table, center, then hand off to the grasp mission.
        No pool-specific dead-reckon constants. See
        docs/superpowers/specs/2026-06-30-octagon-pinger-to-table-design.md.
    -->
    <BehaviorTree ID="OctagonRestoreMission">
        <Sequence>
            <!-- 1. S1: frequency-gated acoustic homing onto the octagon pinger. -->
            <SubTree ID="HomeOnOctagonPinger" _autoremap="true" ctx="{ctx}"/>

            <!-- 2. S2: calibration-free descend + center over the table (no
                 dead-reckon constants; spiral-searches if the table drifts off
                 frame). Shared with the OctagonMission capstone. -->
            <SubTree ID="AcquireTable" _autoremap="true" ctx="{ctx}"/>

            <!-- 3. Hand off to S4 grasp. Knobs mirror octagon_grasp_mission.xml
                 (descend_z / lift_z / angles are sim-measured placeholders). -->
            <SetBlackboard output_key="target_label" value="{grasp_target}"/>
            <SubTree ID="ApproachAndGrasp" _autoremap="true" ctx="{ctx}"
                     grasp_attempts="2"
                     center_tol_norm="0.05" center_timeout_msec="20000"
                     open_angle="85" close_angle="0"
                     descend_z="-0.6" lift_z="0.6"
                     grip_settle_msec="1500" move_timeout_msec="30000"
                     grasp_keep_ratio="0.5"/>
        </Sequence>
    </BehaviorTree>
</root>
