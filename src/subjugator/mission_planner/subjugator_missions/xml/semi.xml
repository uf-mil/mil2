<!--
    Semi
    ==================
    Full run of the first three tasks, chained as subtrees:

      1) CoinFlipMission    - one-shot wall-avoidance maneuver (coin_flip_mission.xml)
         + RememberWaypoint "home" right after it
      2) StartGateApproach  - survey + hone onto {gate_label}, pass the gate
                              (start_gate_mission.xml)
         + GoToWaypointOrientation "home": recover the post-coin-flip heading
           (orientation only, position stays)
      3) RelativeMove       - TUNE ME: re-orient from the gate exit toward the
                              nav channel
      4) pcNavChannelV2     - nav channel run (pc_nav_channel_v2.xml)
         (currently swapped for a dead-reckoned zigzag of RelativeMoves)
      5) RememberWaypoint "post_nav" right after the nav channel leg
      6) OctagonPingerMission - ride the pinger to the octagon
      7) GoToWaypoint "post_nav": return to the post-nav-channel pose
      8) SonarToTorpedoMission - sonar-follow until the torpedo board is
         >=100x100 px on screen, then fire both torpedoes
         (sonar_torpedo_mission.xml)
      9) GoToWaypointPosition "home": drive back to the post-coin-flip spot
         (position only, heading stays)

    The ONE thing to configure is gate_label in the Script node below. The
    nav-channel side follows from it automatically:

      survey&repair  -> LEFT  channel (channel_side = -1)
      search&rescue  -> RIGHT channel (channel_side = +1)

    (& must be written &amp; inside XML attributes.)

    All depth changes are absolute (AbsDepth); pcNavChannelV2 also dives with
    AbsDepth internally, so depths hold no matter where the previous stage
    left us.
-->
<root BTCPP_format="4" main_tree_to_execute="Semi">
  <BehaviorTree ID="Semi">
    <Sequence>
      <Delay delay_msec="10000"><AlwaysSuccess/></Delay>

      <!-- ================= CONFIG =================
           Which gate image to hone onto. This single choice also decides the
           nav-channel side (see Switch2 below). -->
      <Script code="gate_label := 'survey&amp;repair'"/>
      <Script code="gate_label := 'search&amp;rescue'"/>
      <Script code="wall_side := 'right'"/>

      <!-- Map the image choice to the channel side:
           case_1 survey&repair -> -1 (LEFT), case_2 search&rescue -> +1 (RIGHT),
           default (typo safety net) -> 0 = auto-detect from the pole colors. -->
      <Switch2 variable="{gate_label}"
               case_1="survey&amp;repair" case_2="search&amp;rescue">
        <Script code="channel_side := -1"/>
        <Script code="channel_side := 1"/>
        <Script code="channel_side := 0"/>
      </Switch2>

      <!-- 0) Dive to coin-flip depth (absolute). TUNE z. -->
      <SubTree ID="AbsDepth"
               z="-0.75" pos_tol="0.15" ori_tol_deg="12.0" msec="20000"
               ctx="{ctx}"/>

      <!-- 1) Coin flip: single maneuver away from the wall. Launches and
           tears down its own classifier node. -->
	<SubTree ID="CoinFlipMission" _autoremap="true" ctx="{ctx}"/>

     <Action ID="RememberWaypoint" waypoint="home" ctx="{ctx}"/>


      <!-- 2) Start gate: load the gate model, then survey + hone onto the
           chosen image and push through. TUNE model_filename for the pool. -->
      <!-- <Action ID="CheckYoloModel"
              model_filename="startgate_robosub26.pt"
              yolo_node="/yolo/yolo_node"
              models_rel_dir="models"
              ctx="{ctx}"/>
      <SubTree ID="StartGateApproach" _autoremap="true"
      gate_label="{gate_label}" ctx="{ctx}"/> -->

     <Switch2 variable="{gate_label}"
               case_1="search&amp;rescue" case_2="survey&amp;repair">


        <Sequence>
          <SubTree ID="RelativeMove" _autoremap="true"
                 x="4.6" y="0.0" z="0.0"
                 roll_deg="0.0" pitch_deg="0.0" yaw_deg="0.0"
                 pos_tol="0.20" ori_tol_deg="10.0" msec="20000"
                 ctx="{ctx}"/>

          <SubTree ID="RelativeMove" _autoremap="true"
                     y="0.7625"
                     pos_tol="0.15" ori_tol_deg="12.0" msec="20000"
                     ctx="{ctx}"/>
        </Sequence>

        <Sequence>

          <SubTree ID="RelativeMove" _autoremap="true"
                 x="4.6" y="0.0" z="0.0"
                 roll_deg="0.0" pitch_deg="0.0" yaw_deg="0.0"
                 pos_tol="0.20" ori_tol_deg="10.0" msec="20000"
                 ctx="{ctx}"/>


          <SubTree ID="RelativeMove" _autoremap="true"
                     y="-0.7625"
                     pos_tol="0.15" ori_tol_deg="12.0" msec="20000"
                     ctx="{ctx}"/>

          </Sequence>

          <AlwaysSuccess/>
     </Switch2>

     <Sequence>
          <Repeat num_cycles="4">
               <Fallback>
               <SubTree ID="RelativeMove" _autoremap="true"
                         yaw_deg="90.0" pos_tol="0.25" ori_tol_deg="6.0" msec="3500" ctx="{ctx}"/>
               <AlwaysSuccess/>
               </Fallback>
          </Repeat>
     </Sequence>


     <!-- =================   NAVCHANNEL!!!!!! ================= -->
      <!-- 3)
           Adjust once we see where the gate spits us out. -->
           <!-- <SubTree ID="pcNavChannelV2" _autoremap="true"
               channel_side="{channel_side}" ctx="{ctx}"/> -->

     <!-- TUNE ME: re-orient from the gate exit toward the nav channel.
          Side depends on the role: survey&repair -> -0.5, search&rescue -> +0.5
          (channel_side comes from the Switch2 in the CONFIG block). -->
     <Switch2 variable="{gate_label}"
               case_1="search&amp;rescue" case_2="survey&amp;repair">

          <SubTree ID="RelativeMove" _autoremap="true"
                     y="-0.6"
                     pos_tol="0.15" ori_tol_deg="12.0" msec="20000"
                     ctx="{ctx}"/>

          <SubTree ID="RelativeMove" _autoremap="true"
                     y="0.8"
                     pos_tol="0.15" ori_tol_deg="12.0" msec="20000"
                     ctx="{ctx}"/>

          <AlwaysSuccess/>
     </Switch2>


     <SubTree ID="RelativeMove" _autoremap="true"
               x="3.0" y="0.0" z="0.0"
               roll_deg="0.0" pitch_deg="0.0" yaw_deg="0.0"
               pos_tol="0.20" ori_tol_deg="10.0" msec="20000"
               ctx="{ctx}"/>

     <SubTree ID="RelativeMove" _autoremap="true"
               x="2.1" y="1.0" z="0.0"
               roll_deg="0.0" pitch_deg="0.0" yaw_deg="0.0"
               pos_tol="0.20" ori_tol_deg="10.0" msec="20000"
               ctx="{ctx}"/>

     <SubTree ID="RelativeMove" _autoremap="true"
               x="2.1" y="-1.0" z="0.0"
               roll_deg="0.0" pitch_deg="0.0" yaw_deg="0.0"
               pos_tol="0.20" ori_tol_deg="10.0" msec="20000"
               ctx="{ctx}"/>

     <SubTree ID="RelativeMove" _autoremap="true"
               x="1.4" y="0.0" z="0.0"
               roll_deg="0.0" pitch_deg="0.0" yaw_deg="0.0"
               pos_tol="0.20" ori_tol_deg="10.0" msec="20000"
               ctx="{ctx}"/>

      <!-- 5) Mark where the nav channel leg left us; we come back here
           between the octagon and torpedo runs. -->
     <!-- <Action ID="RememberWaypoint" waypoint="post_nav" ctx="{ctx}"/> -->


      <!-- ========  TUNE ME!!  ======= -->

      <!--
     <SubTree ID="RelativeMove" _autoremap="true"
                 x="0.0" y="2.0" z="0.0"
                 roll_deg="0.0" pitch_deg="0.0" yaw_deg="0.0"
                 pos_tol="0.20" ori_tol_deg="10.0" msec="20000"
                 ctx="{ctx}"/>

     <SubTree ID="RelativeMove" _autoremap="true"
                 x="0.0" y="0.0" z="0.0"
                 roll_deg="0.0" pitch_deg="0.0" yaw_deg="20.0"
                 pos_tol="0.20" ori_tol_deg="10.0" msec="20000"
     ctx="{ctx}"/>-->

      <!-- 6) Octagon: ride the pinger to the octagon. -->
      <Fallback>
          <Timeout msec="90000">
              <SubTree ID="OctagonPingerMission" _autoremap="true" ctx="{ctx}"/>
          </Timeout>
          <AlwaysSuccess/>
      </Fallback>

      <!-- 7) Back to the post-nav-channel pose (position + orientation). -->
      <!-- <SubTree ID="GoToWaypoint" _autoremap="true"
               waypoint="post_nav"
               pos_tol="0.25" ori_tol_deg="10.0" msec="90000"
      ctx="{ctx}"/> -->

      <!-- 8) Sonar-follow toward the torpedo board until it is >=100x100 px
           on screen (or the follower passes the ping), then fire both
           torpedoes. Loads the torpedo YOLO model itself, up front. -->
      <!-- <SubTree ID="SonarToTorpedoMission" _autoremap="true" ctx="{ctx}"/> -->

      <!-- 9) Head home: back to the post-coin-flip position, keeping
      whatever heading we finished the torpedo run with. -->

      <SubTree ID="RelativeMove" _autoremap="true"
                yaw_deg="90.0" pos_tol="0.25" ori_tol_deg="6.0" msec="3500" ctx="{ctx}"/>

      <SubTree ID="RelativeMove" _autoremap="true"
                yaw_deg="90.0" pos_tol="0.25" ori_tol_deg="6.0" msec="3500" ctx="{ctx}"/>


      <SubTree ID="GoToWaypointPosition" _autoremap="true"
               waypoint="home"
               pos_tol="0.25" ori_tol_deg="12.0" msec="90000"
               ctx="{ctx}"/>

      <SubTree ID="StylePointsSubmission" _autoremap="true" />

    </Sequence>
  </BehaviorTree>
</root>
