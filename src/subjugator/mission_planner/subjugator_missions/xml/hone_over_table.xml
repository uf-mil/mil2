<root BTCPP_format="4">
    <!--
        Reusable subtree: horizontally center the sub over a table-like object
        seen by the DOWN-facing camera. Centering only -- the caller is
        responsible for reaching hover depth first (e.g. a z-only RelativeMove).

        Vision honing with graceful degradation: CenterCamera closed-loops the
        sub's XY until the detection centroid is centered. If the table is never
        detected or honing exceeds the timeout, the Timeout/CenterCamera branch
        fails and AlwaysSuccess returns SUCCESS so the parent mission continues
        on dead-reckoning instead of blocking.

        Sign/axis ports (swap_axes, map_x_sign, map_y_sign) map image error to
        body surge/sway; defaults are placeholders to be tuned in sim against the
        down-cam mounting.
    -->
    <BehaviorTree ID="HoneOverTable">
        <Fallback>
            <Timeout msec="20000">
                <Action ID="CenterCamera"
                        camera="down"
                        label="table"
                        min_conf="0.30"
                        tol_norm="0.05"
                        kp="0.5"
                        max_step="0.25"
                        settle_pos_tol="0.10"
                        settle_ticks="3"
                        swap_axes="false"
                        map_x_sign="1.0"
                        map_y_sign="1.0"
                        ctx="{ctx}"/>
            </Timeout>
            <AlwaysSuccess/>
        </Fallback>
    </BehaviorTree>
</root>
