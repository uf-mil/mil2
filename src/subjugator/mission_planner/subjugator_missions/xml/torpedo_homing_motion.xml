<root BTCPP_format="4" main_tree_to_execute="TorpedoHomingMotion">
  <BehaviorTree ID="TorpedoHomingMotion">
    <Sequence>

      <!--
        1: Align depth (Z translation only).
        P-controller adjusts Z until the detection bbox is vertically centred.
        max_step_m is kept small so motion is slow and controlled.
        Change "label" to match your YOLO model's class name for the torpedo target.
    -->
    <!--
      <Timeout msec="60000">
        <Action ID="AlignDepth"
                label="Red spiral"
                min_conf="0.30"
                kp="0.8"
                depth_tol_norm="0.08"
                max_step_m="0.15"
                pos_tol="0.10"
                ctx="{ctx}"/>
      </Timeout>
      -->
      <!--
        2: Align yaw (rotation only, no pitch, no translation).
        P-controller yaws until the detection bbox is horizontally centred.
        Runs AFTER depth is aligned.
      -->
      <Timeout msec="45000">
        <Action ID="AlignYaw"
                label="Red spiral"
                min_conf="0.15"
                kp="2"
                yaw_tol_norm="0.15"
                max_yaw_deg="12.0"
                ori_tol_deg="4.0"
                ctx="{ctx}"/>
      </Timeout>

    </Sequence>
  </BehaviorTree>
</root>
