<!--
	Test mission to exercise `ActuateServo` for servo IDs 1 (gripper),
	2 (marble dropper) and 3 (torpedo launcher). Each servo is actuated
	to the TRUE state then to the FALSE state. The `ctx` blackboard key
	must be set in code (e.g. `blackboard->set("ctx", ctx)`).
	Use mission name: `TestServos` when creating the tree.
-->
<root main_tree_to_execute="TestServos">
	<BehaviorTree ID="TestServos">
		<Sequence name="RunAllServos">
			<!-- Gripper: open -->
			<ActuateServo ctx="{ctx}" servo_id="1" gripper_is_open="true"/>

			<!-- Marble dropper: drop -->
			<ActuateServo ctx="{ctx}" servo_id="2" marble_is_drop="true"/>

			<!-- Torpedo launcher: launch -->
			<ActuateServo ctx="{ctx}" servo_id="3" torp_is_launch="true"/>

			<!-- Gripper: close -->
			<ActuateServo ctx="{ctx}" servo_id="1" gripper_is_open="false"/>

			<!-- Marble dropper: reset -->
			<ActuateServo ctx="{ctx}" servo_id="2" marble_is_drop="false"/>

			<!-- Torpedo launcher: reset -->
			<ActuateServo ctx="{ctx}" servo_id="3" torp_is_launch="false"/>

		</Sequence>
	</BehaviorTree>
</root>
