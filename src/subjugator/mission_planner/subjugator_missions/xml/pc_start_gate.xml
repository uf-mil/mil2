<root BTCPP_format="4" main_tree_to_execute="pcStartGate">
  <BehaviorTree ID="pcStartGate">
    <Sequence>

      <!-- Sim model; swap in the real gate model -->
      <Action ID="CheckYoloModel"
              model_filename="start_gate_sim.pt"
              yolo_node="/yolo/yolo_node"
              models_rel_dir="models"
              ctx="{ctx}"/>

      <!-- Sweep until the chosen image is seen. DetectTarget succeeding
           ends the Parallel, halting the sweep mid-step; AlignYaw below
           cleans up the heading. -->
      <Parallel success_count="1" failure_count="2">

        <RetryUntilSuccessful num_attempts="-1">
          <Sequence>
            <Delay delay_msec="200"><AlwaysSuccess/></Delay>
            <Condition ID="DetectTarget"
                       label="{gate_target}" min_conf="0.20" ctx="{ctx}"/>
          </Sequence>
        </RetryUntilSuccessful>

        <Repeat num_cycles="-1">
          <Sequence>
            <Repeat num_cycles="4">
              <Fallback>
                <SubTree ID="RelativeMove" _autoremap="true"
                         yaw_deg="15.0" pos_tol="0.25" ori_tol_deg="6.0" msec="4000" ctx="{ctx}"/>
                <AlwaysSuccess/>
              </Fallback>
            </Repeat>
            <Repeat num_cycles="8">
              <Fallback>
                <SubTree ID="RelativeMove" _autoremap="true"
                         yaw_deg="-15.0" pos_tol="0.25" ori_tol_deg="6.0" msec="4000" ctx="{ctx}"/>
                <AlwaysSuccess/>
              </Fallback>
            </Repeat>
            <Repeat num_cycles="4">
              <Fallback>
                <SubTree ID="RelativeMove" _autoremap="true"
                         yaw_deg="15.0" pos_tol="0.25" ori_tol_deg="6.0" msec="4000" ctx="{ctx}"/>
                <AlwaysSuccess/>
              </Fallback>
            </Repeat>
          </Sequence>
        </Repeat>

      </Parallel>

      <!-- P-control yaw until the image is horizontally centred.
           ForceSuccess: if it times out, drive through anyway. -->
      <ForceSuccess>
        <Timeout msec="30000">
          <Action ID="AlignYaw"
                  label="{gate_target}"
                  min_conf="0.15"
                  kp="1.0"
                  yaw_tol_norm="0.10"
                  max_yaw_deg="15.0"
                  ori_tol_deg="6.0"
                  ctx="{ctx}"/>
        </Timeout>
      </ForceSuccess>

      <!-- Alternative: strafe in Y instead of yawing.
           Swap this in for the AlignYaw block above to test.
      <ForceSuccess>
        <Timeout msec="30000">
          <Action ID="AlignStrafe"
                  label="{gate_target}"
                  min_conf="0.15"
                  kp="0.5"
                  strafe_tol_norm="0.10"
                  max_step_m="0.20"
                  pos_tol="0.10"
                  ctx="{ctx}"/>
        </Timeout>
      </ForceSuccess>
      -->

      <!-- Drive straight through the gate-->
      <SubTree ID="RelativeMove" _autoremap="true"
               x="2.0" y="0.0" z="0.0"
               roll_deg="0.0" pitch_deg="0.0" yaw_deg="0.0"
               pos_tol="0.25" ori_tol_deg="30.0" msec="15000" ctx="{ctx}"/>

    </Sequence>
  </BehaviorTree>
</root>
