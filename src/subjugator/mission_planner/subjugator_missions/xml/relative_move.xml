<root BTCPP_format="4">
    <BehaviorTree ID="RelativeMove">
        <Sequence>
            <Action ID="PublishGoalPose"
                x="{x}" y="{y}" z="{z}"
                use_euler_deg="true"
                roll_deg="{roll_deg}" pitch_deg="{pitch_deg}" yaw_deg="{yaw_deg}"
                relative="true" ctx="{ctx}"
                abs_x="{abs_x}" abs_y="{abs_y}" abs_z="{abs_z}"
                abs_qx="{abs_qx}" abs_qy="{abs_qy}" abs_qz="{abs_qz}" abs_qw="{abs_qw}"/>

            <!-- RosTimeout/RosDelay (not the builtins): the motion budget and the
                 poll pacing elapse in ROS time, so slow-RTF sim rehearsals get the
                 intended sim-seconds of motion (identical at the pool). -->
            <RosTimeout msec="{msec}" ctx="{ctx}">
                <RetryUntilSuccessful num_attempts="-1">
                    <Sequence>
                        <RosDelay delay_msec="50" ctx="{ctx}"><AlwaysSuccess/></RosDelay>
                        <Condition ID="AtGoalPose"
                        x="{abs_x}" y="{abs_y}" z="{abs_z}"
                        qx="{abs_qx}" qy="{abs_qy}" qz="{abs_qz}" qw="{abs_qw}"
                        pos_tol="{pos_tol}" ori_tol_deg="{ori_tol_deg}" ctx="{ctx}"/>
                    </Sequence>
                </RetryUntilSuccessful>
            </RosTimeout>
        </Sequence>
    </BehaviorTree>
</root>
