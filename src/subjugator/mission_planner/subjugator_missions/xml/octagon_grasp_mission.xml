<root BTCPP_format="4" main_tree_to_execute="OctagonGraspMission">
    <BehaviorTree ID="OctagonGraspMission">
        <Sequence>
            <!-- No upstream S3 in this harness; seed the target with a real YOLO grab
                 class from octagon_sim.pt (case-sensitive). Valid grab classes:
                 nut_cylinder, electric_box, pill_cylinder, bandaid_box. The seeded
                 class must be present in the test world and detectable by the down
                 YOLO model, or HoneOverTarget never sees it. Change to suit the test. -->
            <SetBlackboard output_key="target_label" value="nut_cylinder"/>
            <!-- Knobs supplied at the call site (like octagon_table_mission); tune here.
                 descend_z / lift_z / angles are sim-measured placeholders. -->
            <SubTree ID="ApproachAndGrasp" _autoremap="true" ctx="{ctx}"
                     grasp_attempts="2"
                     center_tol_norm="0.05" center_timeout_msec="20000"
                     open_angle="85" close_angle="0"
                     descend_z="-0.6" lift_z="0.6"
                     grip_settle_msec="1500" move_timeout_msec="30000"/>
        </Sequence>
    </BehaviorTree>
</root>
