<root BTCPP_format="4" main_tree_to_execute="OctagonGraspMission">
    <BehaviorTree ID="OctagonGraspMission">
        <Sequence>
            <!-- No upstream S3 in this harness; seed the target from the canonical
                 grasp-target list (mission_planner/config/grasp_targets.yaml), which
                 mission_planner_node loads onto the blackboard as {grasp_target} (the
                 first entry) and the sim <graspable> allowlist reads from the same file.
                 Override grasp_targets_file, or hard-code a value here, to pick another. -->
            <SetBlackboard output_key="target_label" value="{grasp_target}"/>
            <!-- Knobs supplied at the call site (like octagon_table_mission); tune here.
                 descend_z / lift_z / angles are sim-measured placeholders. -->
            <SubTree ID="ApproachAndGrasp" _autoremap="true" ctx="{ctx}"
                     grasp_attempts="2"
                     center_tol_norm="0.05" center_timeout_msec="20000"
                     open_angle="85" close_angle="0"
                     descend_z="-0.6" lift_z="0.6"
                     grip_settle_msec="1500" move_timeout_msec="30000"
                     grasp_keep_ratio="0.5"/>
        </Sequence>
    </BehaviorTree>
</root>
