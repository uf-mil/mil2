<root BTCPP_format="4" main_tree_to_execute="YawStyleTest">
    <BehaviorTree ID="YawStyleTest">
        <Sequence>

            <!-- go down -->
            <SubTree ID="RelativeMove" _autoremap="true"
                x="0.0" y="0.0" z="-1.5"
                pos_tol="0.15" ori_tol_deg="12.0" msec="25000"
                ctx="{ctx}"/>

            <Repeat num_cycles="9">
                  <Fallback>
                    <SubTree ID="RelativeMove" _autoremap="true"
                            yaw_deg="40.0" pos_tol="0.25" ori_tol_deg="6.0" msec="3500" ctx="{ctx}"/>
                    <AlwaysSuccess/>
                  </Fallback>
            </Repeat>
        </Sequence>
    </BehaviorTree>
</root>
