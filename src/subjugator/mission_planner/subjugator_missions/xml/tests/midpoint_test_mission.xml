<root BTCPP_format="4" main_tree_to_execute="HoneMidpointTestMission">
  <BehaviorTree ID="HoneMidpointTestMission">
    <Sequence>

      <!-- Load nav-channel model -->
      <Action ID="CheckYoloModel"
              model_filename="new_sim_nav_channel.pt"
              yolo_node="/yolo/yolo_node"
              models_rel_dir="models"
              ctx="{ctx}"/>

      <!-- Wait until at least some poles are visible -->
      <RetryUntilSuccessful num_attempts="-1">
        <Sequence>
          <Delay delay_msec="200">
            <AlwaysSuccess/>
          </Delay>
          <Action ID="AnyPolesDetected"
                  min_conf="0.15"
                  ctx="{ctx}"/>
        </Sequence>
      </RetryUntilSuccessful>

      <!-- Test HoneMidpoint + RelativeMove closed loop -->
      <Parallel success_count="1" failure_count="1">

        <!-- Branch 1: keep computing yaw_step_deg until centered -->
        <Timeout msec="20000">
          <Action ID="HoneMidpoint"
                  ctx="{ctx}"
                  min_conf="0.15"
                  kp="0.03"
                  max_cmd="3.0"
                  tol_px="10.0"
                  hold_ticks="5"
                  yaw_cmd="{yaw_step_deg}"/>
        </Timeout>

        <!-- Branch 2: keep applying small yaw steps -->
        <Repeat num_cycles="100">
          <Sequence>
            <Delay delay_msec="100">
              <AlwaysSuccess/>
            </Delay>

            <Fallback>
              <SubTree ID="RelativeMove"
                       _autoremap="true"
                       yaw_deg="{yaw_step_deg}"
                       pos_tol="0.25"
                       ori_tol_deg="6.0"
                       msec="600"
                       ctx="{ctx}"/>
              <AlwaysSuccess/>
            </Fallback>
          </Sequence>
        </Repeat>

      </Parallel>

      <!-- Optional tiny forward nudge after successful centering -->
      <SubTree ID="RelativeMove"
               _autoremap="true"
               x="0.5"
               pos_tol="0.25"
               ori_tol_deg="20.0"
               msec="4000"
               ctx="{ctx}"/>

    </Sequence>
  </BehaviorTree>
</root>
