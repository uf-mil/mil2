<root BTCPP_format="4" main_tree_to_execute="OctagonPingerMission">
    <BehaviorTree ID="OctagonPingerMission">
        <Sequence>
            <SubTree ID="AbsDepth"
                     z="-0.6" pos_tol="0.15" ori_tol_deg="10.0" msec="20000"
                     ctx="{ctx}"/>

            <!-- Follow pinger bearing updates until the follower marks target passed. -->
            <SonarFollower
                name="follow_ping_to_octagon"
                ctx="{ctx}"
                required_passing_pings="3"
                sonar_x="{sonar_x}" sonar_y="{sonar_y}" sonar_yaw_deg="{sonar_yaw_deg}">
                <SubTree ID="RelativeMove" _autoremap="true"
                    x="{sonar_x}" y="{sonar_y}" z="0.0"
                    yaw_deg="{sonar_yaw_deg}"
                    pos_tol="0.20" ori_tol_deg="12.0" msec="25000"
                    ctx="{ctx}"/>
            </SonarFollower>

            <!-- At the octagon: surface to -0.2 m (absolute), then settle
                 back down to -0.6 m before handing off to the next task. -->
            <Fallback>
              <SubTree ID="AbsDepth"
                       z="-0.01" pos_tol="0.15" ori_tol_deg="10.0" msec="10000"
                       ctx="{ctx}"/>
              <AlwaysSuccess/>
            </Fallback>

            <Delay delay_msec="3000"><AlwaysSuccess/></Delay>

            <SubTree ID="AbsDepth"
                     z="-0.6" pos_tol="0.15" ori_tol_deg="10.0" msec="20000"
                     ctx="{ctx}"/>

        </Sequence>
    </BehaviorTree>
</root>
