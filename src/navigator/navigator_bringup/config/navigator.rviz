                    {}
          wamv/front_right_cam_post_link:
            wamv/front_right_cam_post_arm_link:
              wamv/front_right_cam_link:
                wamv/front_right_cam_link_optical:
                  navigator/wamv/base_link/front_right_cam_sensor:
                    {}
